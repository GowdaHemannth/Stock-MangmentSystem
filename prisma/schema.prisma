generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Stock {
  id           Int    @id @default(autoincrement())
  materialName String @unique
  quantity     Float
  unit         String
}

model ProductionRule {
  id               Int    @id @default(autoincrement())
  product          String
  material         String
  quantityRequired Float
}

model ProductionHistory {
  id       Int      @id @default(autoincrement())
  product  String
  quantity Int
  metadata String?
  date     DateTime @default(now())
}

model AuthorizedUser {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
